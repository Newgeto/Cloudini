# Copier ce fichier en .env puis adapter les valeurs.

# Clé secrète de signature des JWT (générer une valeur aléatoire en production,
# ex: python -c "import secrets; print(secrets.token_hex(32))").
SECRET_KEY=changeme-genere-une-cle-aleatoire

# Durée de validité d'un token d'accès, en minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Dossier de stockage des fichiers uploadés (relatif au dossier api/).
STORAGE_DIR=storage

# Origines autorisées à appeler l'API (CORS), séparées par des virgules.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Taille maximale d'un upload, en méga-octets.
MAX_UPLOAD_MB=10

# Extensions autorisées (sans le point), séparées par des virgules. Vide = tout autorisé.
ALLOWED_EXTENSIONS=txt,md,csv,pdf,png,jpg,jpeg,gif,webp,doc,docx,xls,xlsx,zip
